# RouterAI API
ROUTERAI_API_KEY=sk-...
ROUTERAI_BASE_URL=https://routerai.ru/api/v1

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
COLLECTION_NAME=BASHKIR_ENERGO_PERPLEXITY

# Embedding
EMBEDDING_MODEL=perplexity/pplx-embed-v1-4b
EMBEDDING_DIM=2560

# LLM — per-agent models for optimal speed/quality tradeoff
# Speed-critical agents (QueryGenerator, intermediate steps): inception/mercury-2
# Quality-critical agents (ResponseAgent, Judge): deepseek/deepseek-v4-flash
DEFAULT_LLM_MODEL=deepseek/deepseek-v4-flash
QUERY_GENERATOR_MODEL=inception/mercury-2
RESPONSE_AGENT_MODEL=deepseek/deepseek-v4-flash
JUDGE_LLM_MODEL=deepseek/deepseek-v4-flash

# Search weights (default, LLM can override)
RETRIEVE_PREF_WEIGHT=0.4
RETRIEVE_HYPE_WEIGHT=0.3
RETRIEVE_LEXICAL_WEIGHT=0.2
RETRIEVE_CONTEXTUAL_WEIGHT=0.1

# Supabase (Chat History & Feedback)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# JWT Auth
JWT_SECRET_KEY=your-secret-key-change-in-production

# Langfuse Observability
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com
ENABLE_LANGFUSE=true
