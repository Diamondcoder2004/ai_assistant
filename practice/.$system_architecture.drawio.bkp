          <mxGeometry height="80" width="120" x="580" y="50" as="geometry" />
        </mxCell>

        <!-- Arrow: Frontend -> Backend -->
        <mxCell id="e-fe-be" edge="1" parent="1" source="fe-nginx" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#333333;fontSize=10;fontColor=#000000;" target="be-api" value="REST API&#10;JWT Auth">
          <mxGeometry relative="1" as="geometry">
