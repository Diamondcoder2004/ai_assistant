<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/29.6.6 Chrome/144.0.7559.236 Electron/40.8.4 Safari/537.36" version="29.6.6">
  <diagram id="page-1" name="Архитектура системы">
    <mxGraphModel dx="1042" dy="660" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;fontSize=18;fontStyle=1;align=center;fontColor=#000000;" value="Архитектура системы интеллектуального ассистента Башкирэнерго" vertex="1">
          <mxGeometry height="30" width="800" x="400" y="15" as="geometry" />
        </mxCell>

        <!-- ==================== КЛИЕНТСКИЙ СЛОЙ: СЕРЫЙ ==================== -->
        <mxCell id="layer-client" parent="1" style="swimlane;startSize=30;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=13;fontColor=#000000;" value="Клиентский слой" vertex="1">
          <mxGeometry height="120" width="1500" x="50" y="70" as="geometry" />
        </mxCell>
        <mxCell id="client-user" parent="layer-client" style="ellipse;whiteSpace=wrap;fillColor=#ffffff;strokeColor=#666666;fontSize=11;fontColor=#000000;fontStyle=1" value="Пользователь" vertex="1">
          <mxGeometry height="60" width="120" x="690" y="40" as="geometry" />
        </mxCell>

        <!-- Arrow: User -> Frontend -->
        <mxCell id="e-user-fe" edge="1" parent="1" source="client-user" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#333333;fontSize=10;fontColor=#000000;" target="fe-vue" value="HTTP-запрос">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="800" y="220" />
              <mxPoint x="800" y="240" />
            </Array>
          </mxGeometry>
