# ===========================================
# AI Assistant Configuration Template
# ===========================================
# Скопируйте этот файл в .env и заполните значения

# ===========================================
# Qdrant Vector Database
# ===========================================
QDRANT_HOST=qdrant
QDRANT_PORT=6333
NORMATIVE_COLLECTION=normative_documents
OPERATIONAL_COLLECTION=operational_content
CHUNKS_DIR=chunking/enriched_chunks
# COLLECTION_NAME is deprecated — use NORMATIVE_COLLECTION + OPERATIONAL_COLLECTION

# ===========================================
# RouterAI (LLM & Embeddings)
# ===========================================
ROUTERAI_API_KEY=your-routerai-api-key
ROUTERAI_BASE_URL=https://routerai.ru/api/v1

EMBEDDING_MODEL=perplexity/pplx-embed-v1-4b
EMBEDDING_DIM=2560
DEFAULT_LLM_MODEL=deepseek/deepseek-v4-flash
# Per-agent models for optimal speed/quality tradeoff:
QUERY_GENERATOR_MODEL=inception/mercury-2
RESPONSE_AGENT_MODEL=deepseek/deepseek-v4-flash
JUDGE_LLM_MODEL=deepseek/deepseek-v4-flash

# ===========================================
# Supabase (Database & Auth)
# ===========================================
# Для подключения к локальному Supabase (Docker):
# SUPABASE_URL=http://host.docker.internal:8000
# Для подключения к облачному Supabase:
# SUPABASE_URL=https://your-project.supabase.co

SUPABASE_URL=http://host.docker.internal:8000
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ===========================================
# JWT Authentication
# ===========================================
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256

# ===========================================
# Search Weights (Hybrid Search)
# ===========================================
RETRIEVE_PREF_WEIGHT=0.25
RETRIEVE_HYPE_WEIGHT=0.25
RETRIEVE_CONTEXTUAL_WEIGHT=0.25
RETRIEVE_LEXICAL_WEIGHT=0.25

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=INFO

# ===========================================
# Agent Debug Logging
# ===========================================
# Включить детальное логирование агентов (true/false)
AGENT_DEBUG_ENABLED=false

# Логировать промпты (true/false) - может содержать чувствительные данные
AGENT_DEBUG_LOG_PROMPTS=false

# ===========================================
# Langfuse Observability (Traces & Cost Tracking)
# ===========================================
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_BASE_URL=https://cloud.langfuse.com
ENABLE_LANGFUSE=true

# Model pricing in руб per 1 token (×1e-6 from руб/1M tokens)
# Prices: inception/mercury-2 ~1.5/4.5₽ per 1M tokens, deepseek-v3.2 ~0.75/2.25₽, embed ~0.1₽
LANGFUSE_MODEL_PRICES=[{"model_name":"inception/mercury-2","match_pattern":"inception/mercury-2","input_price":0.0000015,"output_price":0.0000045},{"model_name":"deepseek/deepseek-v4-flash","match_pattern":"deepseek/deepseek-v4-flash","input_price":0.00000075,"output_price":0.00000225},{"model_name":"deepseek/deepseek-v3.2","match_pattern":"deepseek/deepseek-v3.2","input_price":0.00000075,"output_price":0.00000225},{"model_name":"perplexity/pplx-embed-v1-4b","match_pattern":"perplexity/pplx-embed-v1-4b","input_price":0.0000001,"output_price":0}]
