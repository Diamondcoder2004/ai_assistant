<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/29.6.6 Chrome/144.0.7559.236 Electron/40.8.4 Safari/537.36" version="29.6.6">
  <diagram id="page-1" name="Архитектура системы - компактная">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Title -->
        <mxCell id="title" parent="1" style="text;fontSize=22;fontStyle=1;align=center;fontColor=#1a1a1a;" value="Архитектура системы интеллектуального ассистента Башкирэнерго" vertex="1">
          <mxGeometry height="35" width="800" x="300" y="15" as="geometry" />
        </mxCell>
        
        <!-- ==================== Row 1: Client + Frontend ==================== -->
        
        <!-- User -->
        <mxCell id="user" parent="1" style="ellipse;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;fontColor=#000000;fontStyle=1;shadow=1;" value="👤 Пользователь" vertex="1">
          <mxGeometry height="50" width="120" x="40" y="80" as="geometry" />
        </mxCell>
        
        <!-- Frontend Layer -->
        <mxCell id="layer-frontend" parent="1" style="swimlane;startSize=28;fillColor=#fff3e0;strokeColor=#e65100;fontStyle=1;fontSize=13;fontColor=#e65100;rounded=1;arcSize=8;shadow=1;" value="Frontend (Vue.js 3)" vertex="1">
          <mxGeometry height="140" width="380" x="200" y="70" as="geometry" />
        </mxCell>
        
        <!-- Nginx -->
        <mxCell id="fe-nginx" parent="layer-frontend" style="rounded=1;whiteSpace=wrap;fillColor=#ffffff;strokeColor=#e65100;fontSize=11;fontColor=#000000;fontStyle=1;shadow=1;" value="Nginx&#xa;Reverse Proxy" vertex="1">
          <mxGeometry height="50" width="100" x="20" y="40" as="geometry" />
        </mxCell>
        
        <!-- Vue SPA -->
        <mxCell id="fe-vue" parent="layer-frontend" style="rounded=1;whiteSpace=wrap;fillColor=#ffffff;strokeColor=#e65100;fontSize=11;fontColor=#000000;shadow=1;" value="Vue.js SPA&#xa;Чат / История" vertex="1">
          <mxGeometry height="50" width="110" x="140" y="40" as="geometry" />
        </mxCell>
        
        <!-- Auth -->
        <mxCell id="fe-auth" parent="layer-frontend" style="rounded=1;whiteSpace=wrap;fillColor=#ffffff;strokeColor=#e65100;fontSize=11;fontColor=#000000;shadow=1;" value="Auth UI&#xa;JWT" vertex="1">
          <mxGeometry height="50" width="90" x="270" y="40" as="geometry" />
        </mxCell>
        
        <!-- ==================== Row 2: Backend ==================== -->
        
        <!-- Backend Layer -->
        <mxCell id="layer-backend" parent="1" style="swimlane;startSize=28;fillColor=#e3f2fd;strokeColor=#1976d2;fontStyle=1;fontSize=13;fontColor=#1565c0;rounded=1;arcSize=8;shadow=1;" value="Backend (FastAPI)" vertex="1">
          <mxGeometry height="200" width="700" x="200" y="240" as="geometry" />
        </mxCell>
        
        <!-- API Endpoints -->
        <mxCell id="be-api" parent="layer-backend" style="rounded=1;whiteSpace=wrap;fillColor=#ffffff;strokeColor=#1976d2;fontSize=11;fontColor=#000000;fontStyle=1;shadow=1;" value="API Endpoints&#xa;/query /history /feedback" vertex="1">
          <mxGeometry height="50" width="130" x="20" y="40" as="geometry" />
        </mxCell>
        
        <!-- Agents Container -->
        <mxCell id="be-agents" parent="layer-backend" style="swimlane;startSize=22;fillColor=#bbdefb;strokeColor=#1976d2;fontStyle=1;fontSize=11;fontColor=#1565c0;rounded=1;arcSize=6;" value="Агенты" vertex="1">
          <mxGeometry height="130" width="340" x="170" y="35" as="geometry" />
        </mxCell>
        
        <!-- Query Generator -->
        <mxCell id="be-query" parent="be-agents" style="rounded=1;whiteSpace=wrap;fillColor=#ffffff;strokeColor=#1976d2;fontSize=10;fontColor=#000000;shadow=1;" value="Query Generator&#xa;Классификация" vertex="1">
          <mxGeometry height="45" width="100" x="10" y="30" as="geometry" />
        </mxCell>
        
        <!-- Search Agent -->
        <mxCell id="be-search" parent="be-agents" style="rounded=1;whiteSpace=wrap;fillColor=#ffffff;strokeColor=#1976d2;fontSize=10;fontColor=#000000;shadow=1;" value="Search Agent&#xa;Гибридный поиск" vertex="1">
          <mxGeometry height="45" width="100" x="120" y="30" as="geometry" />
        </mxCell>
        
        <!-- Response Agent -->
        <mxCell id="be-response" parent="be-agents" style="rounded=1;whiteSpace=wrap;fillColor=#ffffff;strokeColor=#1976d2;fontSize=10;fontColor=#000000;shadow=1;" value="Response Agent&#xa;Генерация ответа" vertex="1">
          <mxGeometry height="45" width="100" x="230" y="30" as="geometry" />
        </mxCell>
        
        <!-- RouterAI -->
        <mxCell id="be-routerai" parent="layer-backend" style="rounded=1;whiteSpace=wrap;fillColor=#fff3e0;strokeColor=#f57c00;fontSize=11;fontColor=#000000;fontStyle=1;shadow=1;" value="RouterAI&#xa;Mercury 2 LLM" vertex="1">
          <mxGeometry height="50" width="120" x="560" y="40" as="geometry" />
        </mxCell>
        
        <!-- Embeddings -->
        <mxCell id="be-embeddings" parent="layer-backend" style="rounded=1;whiteSpace=wrap;fillColor=#ffffff;strokeColor=#1976d2;fontSize=10;fontColor=#000000;shadow=1;" value="Embeddings&#xa;pplx-embed-v1-4b" vertex="1">
          <mxGeometry height="45" width="110" x="560" y="120" as="geometry" />
        </mxCell>
        
        <!-- ==================== Row 3: Data Layer ==================== -->
        
        <!-- Data Layer -->
        <mxCell id="layer-data" parent="1" style="swimlane;startSize=28;fillColor=#e8f5e9;strokeColor=#388e3c;fontStyle=1;fontSize=13;fontColor=#2e7d32;rounded=1;arcSize=8;shadow=1;" value="Слой данных" vertex="1">
          <mxGeometry height="140" width="700" x="200" y="470" as="geometry" />
        </mxCell>
        
        <!-- Supabase -->
        <mxCell id="db-supabase" parent="layer-data" style="shape=cylinder3;whiteSpace=wrap;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#ffffff;strokeColor=#388e3c;fontSize=11;fontColor=#000000;fontStyle=1;shadow=1;" value="Supabase&#xa;PostgreSQL" vertex="1">
          <mxGeometry height="90" width="120" x="30" y="35" as="geometry" />
        </mxCell>
        
        <!-- Qdrant -->
        <mxCell id="db-qdrant" parent="layer-data" style="shape=cylinder3;whiteSpace=wrap;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#ffffff;strokeColor=#388e3c;fontSize=11;fontColor=#000000;fontStyle=1;shadow=1;" value="Qdrant&#xa;Vector DB" vertex="1">
          <mxGeometry height="90" width="120" x="180" y="35" as="geometry" />
        </mxCell>
        
        <!-- RouterAI Cloud -->
        <mxCell id="cloud-routerai" parent="layer-data" style="ellipse;shape=cloud;whiteSpace=wrap;fillColor=#fff3e0;strokeColor=#f57c00;fontSize=11;fontColor=#000000;fontStyle=1;shadow=1;" value="RouterAI Cloud&#xa;LLM + Embeddings" vertex="1">
          <mxGeometry height="100" width="200" x="340" y="30" as="geometry" />
        </mxCell>
        
        <!-- ==================== Connections ==================== -->
        
        <!-- User → Frontend -->
        <mxCell id="edge-user-fe" edge="1" parent="1" source="user" target="fe-nginx" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#666666;endArrow=classic;endFill=1;" value="HTTP">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- Frontend → Backend -->
        <mxCell id="edge-fe-be" edge="1" parent="1" source="fe-nginx" target="be-api" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#333333;endArrow=classic;endFill=1;" value="REST API&#xa;JWT">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="400" y="200" />
              <mxPoint x="280" y="200" />
            </Array>
          </mxGeometry>
        </mxCell>
        
        <!-- API → Query Generator -->
        <mxCell id="edge-api-query" edge="1" parent="layer-backend" source="be-api" target="be-query" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#1976d2;endArrow=classic;endFill=1;" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- Query → Search -->
        <mxCell id="edge-query-search" edge="1" parent="be-agents" source="be-query" target="be-search" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#1976d2;endArrow=classic;endFill=1;" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- Search → Response -->
        <mxCell id="edge-search-response" edge="1" parent="be-agents" source="be-search" target="be-response" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#1976d2;endArrow=classic;endFill=1;" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- Response → RouterAI -->
        <mxCell id="edge-response-router" edge="1" parent="layer-backend" source="be-response" target="be-routerai" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#f57c00;endArrow=classic;endFill=1;" value="LLM">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- Backend → Supabase -->
        <mxCell id="edge-be-supabase" edge="1" parent="1" source="be-api" target="db-supabase" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#388e3c;endArrow=classic;endFill=1;" value="Auth&#xa;History">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="280" y="400" />
              <mxPoint x="290" y="400" />
            </Array>
          </mxGeometry>
        </mxCell>
        
        <!-- Search → Qdrant -->
        <mxCell id="edge-search-qdrant" edge="1" parent="1" source="be-search" target="db-qdrant" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#388e3c;endArrow=classic;endFill=1;" value="Поиск">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="380" y="400" />
              <mxPoint x="440" y="400" />
            </Array>
          </mxGeometry>
        </mxCell>
        
        <!-- RouterAI → Cloud -->
        <mxCell id="edge-router-cloud" edge="1" parent="1" source="be-routerai" target="cloud-routerai" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#f57c00;endArrow=classic;endFill=1;dashed=1;" value="API">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="820" y="400" />
              <mxPoint x="640" y="400" />
            </Array>
          </mxGeometry>
        </mxCell>
        
        <!-- Embeddings → Cloud -->
        <mxCell id="edge-embed-cloud" edge="1" parent="layer-data" source="be-embeddings" target="cloud-routerai" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#f57c00;endArrow=classic;endFill=1;dashed=1;" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- Legend -->
        <mxCell id="legend" parent="1" style="swimlane;startSize=22;fillColor=#fafafa;strokeColor=#999999;fontStyle=1;fontSize=10;fontColor=#333333;rounded=1;arcSize=6;" value="📋 Легенда" vertex="1">
          <mxGeometry height="70" width="180" x="40" y="640" as="geometry" />
        </mxCell>
        <mxCell id="legend-1" parent="legend" style="text;fontSize=9;fontColor=#666666;align=left;spacingLeft=8;" value="Сплошная: прямой вызов" vertex="1">
          <mxGeometry height="16" width="160" x="10" y="26" as="geometry" />
        </mxCell>
        <mxCell id="legend-2" parent="legend" style="text;fontSize=9;fontColor=#666666;align=left;spacingLeft=8;" value="Пунктирная: облачный API" vertex="1">
          <mxGeometry height="16" width="160" x="10" y="44" as="geometry" />
        </mxCell>
        
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
