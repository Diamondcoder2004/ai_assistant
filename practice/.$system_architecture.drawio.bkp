        <mxCell id="e-prompts-resp" edge="1" parent="layer-backend" source="be-prompts" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=1;strokeColor=#4285f4;dashed=1;" target="be-response" value="">
