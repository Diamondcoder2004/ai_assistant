        </mxCell>
        <mxCell id="chat-methods" parent="chat-store" style="text;fontSize=11;fontColor=#1976d2;align=left;spacingLeft=10;fontStyle=0;" value="+ sendQuestion()&#xa;+ newChat()&#xa;+ loadHistory()&#xa;+ submitFeedback()" vertex="1">
