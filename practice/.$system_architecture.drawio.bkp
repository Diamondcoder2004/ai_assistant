        <mxCell id="fe-vue" parent="layer-frontend" style="rounded=1;whiteSpace=wrap;fillColor=#ffffff;strokeColor=#e65100;fontSize=10;fontColor=#000000;" value="Vue.js SPA&#xa;Чат-интерфейс&#xa;История / Профиль" vertex="1">
          <mxGeometry height="80" width="160" x="30" y="50" as="geometry" />
