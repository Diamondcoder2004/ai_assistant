        <mxCell id="auth-methods" parent="auth-store" style="text;fontSize=11;fontColor=#1976d2;align=left;spacingLeft=10;fontStyle=0;" value="+ login()&#xa;+ register()&#xa;+ logout()" vertex="1">
          <mxGeometry height="60" width="160" x="10" y="75" as="geometry" />
